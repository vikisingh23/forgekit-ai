# NeuraForge AI — Environment Variables
# Copy this file to .env and fill in the values you need.
# Only servers you use need their tokens configured.

# GitHub MCP Server (for PR reviews, repo operations)
# Get a token at: https://github.com/settings/tokens
GITHUB_TOKEN=

# Short Video Maker (for video creation with stock footage)
# Get a key at: https://www.pexels.com/api/
PEXELS_API_KEY=

# SonarQube MCP Server (for code quality analysis)
# Your SonarQube instance URL and token
SONAR_HOST_URL=
SONAR_TOKEN=

# Figma DevMode (for design-to-code)
# Uses Figma's HTTP MCP — authenticate via Figma app
# No env var needed, uses browser auth
